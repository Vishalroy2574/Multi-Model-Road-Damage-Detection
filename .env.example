
# Email/password auth only allows @gmail.com addresses

# AI pothole check: auto tries OpenAI if OPENAI_API_KEY is set, else image heuristic, else accepts
# openai | auto | sharp | demo_valid | demo_invalid
# DETECTION_MODE=auto
# OPENAI_API_KEY=

# Optional Gemini vision support
# If GEMINI_API_KEY is set, the app can use Gemini automatically in auto mode.
GEMINI_API_KEY=
# Optional override if Google changes the default model name again.
# GEMINI_MODEL=gemini-2.5-flash
# USE_GEMINI=true

# Optional: boost priority for reports near a coordinate (e.g. city center)
# TRIAGE_CENTER_LAT=
# TRIAGE_CENTER_LNG=
# TRIAGE_HOTSPOT_KM=8
# TRIAGE_HOTSPOT_PRIORITY_BOOST=12
# TRIAGE_DISABLE_HOTSPOT=0

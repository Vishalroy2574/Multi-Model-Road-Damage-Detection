<% if (user) { %>
<nav class="navbar navbar-dark bg-dark fixed-top border-bottom border-secondary">
  <div class="container-fluid">
    <button class="btn btn-outline-light me-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#sideMenu" aria-controls="sideMenu" aria-label="Menu">Menu</button>
    <span class="navbar-brand mb-0 h1 text-primary">Road Damage Reporter</span>
    <span class="text-secondary small d-none d-md-inline">
      Signed in as <%= user.emailId %>
      <% if (user.role) { %>
      <span class="badge bg-secondary ms-2 text-uppercase"><%= user.role %></span>
      <% } %>
    </span>
  </div>
</nav>

<div class="offcanvas offcanvas-start text-bg-dark" tabindex="-1" id="sideMenu">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title">Menu</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body">
    <ul class="nav flex-column gap-2">
      <% if (user.role === 'authority' || user.role === 'admin') { %>
      <li><a class="btn btn-outline-light w-100 text-start" href="/authority">Authority Panel</a></li>
      <% } %>
      <li><a class="btn btn-outline-light w-100 text-start" href="/dashboard">All Reports</a></li>
      <li><a class="btn btn-outline-light w-100 text-start" href="/report">New report</a></li>
      <li><a class="btn btn-outline-light w-100 text-start" href="/routing">Route it</a></li>
      <li><a class="btn btn-outline-light w-100 text-start" href="/profile">Profile</a></li>
      <li><hr class="border-secondary" /></li>
      <li><a class="btn btn-outline-danger w-100 text-start" href="/logout">Logout</a></li>
    </ul>
  </div>
</div>
<% } %>
